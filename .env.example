# ---- Database ----
DATABASE_URL=postgresql+psycopg://inboxzero:inboxzero@postgres:5432/inboxzero

# ---- Redis (Celery broker + result backend) ----
REDIS_URL=redis://redis:6379/0

# ---- Auth ----
# JWT_SECRET is also accepted (backward compatible)
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- AI provider ----
# One of: openai | anthropic
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# ---- Worker / retry tuning ----
CELERY_MAX_RETRIES=3
CELERY_RETRY_BACKOFF=2
WORKER_CONCURRENCY=3
STALE_PROCESSING_MINUTES=5

# ---- Batch limits ----
MAX_BATCH_ITEMS=50

# ---- CORS / frontend ----
# Comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000
# Deployed Vercel URL (also added to CORS automatically if set)
FRONTEND_URL=

# ---- Runtime ----
ENV=development

# ---- Frontend (Next.js — set in Vercel dashboard or frontend/.env.local) ----
NEXT_PUBLIC_API_URL=http://localhost:8000
